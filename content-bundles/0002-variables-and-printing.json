  "sections": [
    {
      "id": "0002:s1",
      "heading": "Variables are named boxes",
      "bodyHtml": "<pre><code>name := \"Alex\"</code></pre><p>The <code>:=</code> symbol means declare and assign — you will use it constantly.</p>",
      "sortOrder": 1
    },
    {
      "id": "0002:s2",
      "heading": "Types",
      "bodyHtml": "<pre><code>name := \"Alex\"   // string\nage  := 25       // int\ndone := false    // bool</code></pre>",
      "sortOrder": 2
    },
    {
      "id": "0002:s3",
      "heading": "Printing variables",
      "bodyHtml": "<pre><code>fmt.Println(\"Name:\", name)\nfmt.Println(name, age)</code></pre><p>Println prints each argument separated by spaces.</p>",
      "sortOrder": 3
    }
  ],
